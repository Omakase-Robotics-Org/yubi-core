# ROS 2 environment variables
ROS_DISTRO=jazzy  # Options: jazzy, humble, kilted
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp # rmw_cyclonedds_cpp or rmw_fastrtps_cpp
FASTDDS_PROFILE_HOST_PATH=./docker/fastdds_profile.xml
# ROS_AUTOMATIC_DISCOVERY_RANGE=SUBNET # uncomment this line if you want to limit ROS 2 discovery to the local subnet

# Data collection node parameters (S3, API, GC, etc.) are in robot_config.yaml.
# See yubi-core/config/robot_config.yaml.sample.
DATA_MOUNT_PATH=${PWD}/data

# MinIO server credentials (used by the MinIO container, not by ROS nodes)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_DATA_PATH=./minio_data

# Sentry error tracking (optional)
SENTRY_DSN=
ENV=development  # Sentry environment tag

# Build metadata (set by CI, baked into Docker image)
GIT_HASH=
GIT_BRANCH=

# Web video server
WEB_VIDEO_SERVER_PORT=9091
